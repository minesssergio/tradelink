{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../schwab && npm install && cd ../api && npm install",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.ts": { "maxDuration": 300 }
  },
  "crons": [
    { "path": "/api/v1/cron/sync", "schedule": "0 22 * * 1-5" }
  ]
}
